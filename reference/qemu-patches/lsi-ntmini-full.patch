+/*
+ * NTMINI_PA_FIXUP: Win98's VxD_PageAllocateDMA reports
+ * PA = VA - 0xC0000000 when VMM _PageAllocate/_CopyPageTable fail
+ * to fill PhysAddr. For pages not identity-mapped in kernel space,
+ * the reported PA is wrong and PCI DMA reads return zero.
+ *
+ * Strategy: Reconstruct VA by adding 0xC0000000 back, then walk
+ * guest page tables via cpu_get_phys_page_debug() to get the real
+ * physical page. Cache 64 entries direct-mapped. Only attempt for
+ * DMA below 1GB (the VxD identity-map range).
+ *
+ * Translated addresses go through system address_space_memory
+ * (not PCI DMA) because pci_dma_read on translated PAs returns zero.
+ */
+#define LSI_FIXUP_CACHE_SZ 64
+static hwaddr lsi_fixup_cache_tag[LSI_FIXUP_CACHE_SZ];
+static hwaddr lsi_fixup_cache_pa[LSI_FIXUP_CACHE_SZ];
+static bool lsi_fixup_cache_inited;
+
+static hwaddr lsi_fixup_addr(dma_addr_t addr, bool *translated)
+{
+    hwaddr page_tag;
+    unsigned int idx;
+    vaddr va;
+    hwaddr real_pa;
+
+    *translated = false;
+    if (addr >= 0x40000000) {
+        return addr;
+    }
+    if (!lsi_fixup_cache_inited) {
+        memset(lsi_fixup_cache_tag, 0xff, sizeof(lsi_fixup_cache_tag));
+        memset(lsi_fixup_cache_pa, 0, sizeof(lsi_fixup_cache_pa));
+        lsi_fixup_cache_inited = true;
+    }
+
+    page_tag = addr & ~(hwaddr)0xfff;
+    idx = (unsigned int)(page_tag >> 12) & (LSI_FIXUP_CACHE_SZ - 1);
+    if (lsi_fixup_cache_tag[idx] == page_tag) {
+        if (lsi_fixup_cache_pa[idx] == page_tag) {
+            return addr; /* identity */
+        }
+        *translated = true;
+        return lsi_fixup_cache_pa[idx] | (addr & 0xfff);
+    }
 
+    /* Cache miss: need CPU context for page table walk */
+    if (!current_cpu) {
+        return addr;
+    }
+    va = (vaddr)addr + 0xC0000000;
+    real_pa = cpu_get_phys_page_debug(current_cpu, va);
+    if (real_pa == (hwaddr)-1) {
+        return addr; /* walk failed: leave as-is */
+    }
+
+    lsi_fixup_cache_tag[idx] = page_tag;
+    lsi_fixup_cache_pa[idx] = real_pa;
+    if (real_pa == page_tag) {
+        return addr;
+    }
+    *translated = true;
+    return real_pa | (addr & 0xfff);
+}
