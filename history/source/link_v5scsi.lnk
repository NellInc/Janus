format windows vxd dynamic
name V5SCSI.VXD
file vxdwrap_nasm.obj
file V5SCSI_c.obj
file V5SCSI_pe.obj
export NTMINI_DDB
option quiet
option map=V5SCSI.MAP
order
    clname LCODE
        segment _LTEXT
        segment _LDATA
        segment _TEXT
        segment _DATA
        segment _BSS
        segment CONST
        segment CONST2
        segment _TLS
