.venv/
__pycache__/
*.pyc
*.obj
*.MAP
*.err
.DS_Store
logs/

# --- 2026-05-30: keep transient / binary / copyright material out of the public repo ---
# transient experiment + instrumentation dumps
artifacts/
artifacts_*/
# built and vendor driver binaries — load drivers from your OWN media, do not redistribute
binaries/
*.VXD
*.vxd
*.sys
*.SYS
*.PDR
*.pdr
*.mpd
*.MPD
# copyright reference material (incl. vendor DDK headers, scanned books)
*.pdf
reference/
# local harness / environment config (may contain secrets)
*.env
# stray top-level build outputs
/E
/x
# Embedded third-party driver binaries (byte-array headers) embed proprietary vendor
# .sys/.vxd files. Keep them OUT of public mirrors; users regenerate them from their own
# licensed driver copies via tools/embed_sys.py.
source/*_EMBEDDED.H

# Vogons forum-post draft — not part of the published framework
VOGONS_POST_DRAFT.md
